      "url": "https://www.sciencedirect.com/science/article/pii/S0306452226002198?dgcid=rss_sd_all",
      "title": "Temporal dynamics of olfactory training\u2013induced neuroplasticity: an fMRI study using variable-onset hemodynamic response modelling",
      "content": "<p>Publication date: 25 May 2026</p><p><b>Source:</b> Neuroscience, Volume 603</p><p>Author(s): Hanani Abdul Manan, Mei Ren, Zetian Li, Divesh Thaploo, Thomas Hummel</p>",
      "author": "",
      "published_date": null,
      "source": "Neuroscience Journal",
      "status": "pending",
      "priority": "medium",
      "tags": [],
      "word_count": 19,
      "reading_time": 1,
      "created_at": "2026-04-08T11:31:52.291202+00:00",
